# ─── Nexus Social — Environment Variables ────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. Never commit .env to git (it's already in .gitignore)
#
# To get TURSO_DATABASE_URL and TURSO_AUTH_TOKEN run setup.sh

# ── Turso (cloud database) ────────────────────────────────────────────────────
# Required in production. When absent, app uses a local SQLite file (data.db).
TURSO_DATABASE_URL=libsql://nexus-social-YOURNAME.turso.io
TURSO_AUTH_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
# Protects the audit log endpoint: GET /api/admin/security-events
# Set to any long random string. Keep secret.
ADMIN_SECRET=change_me_to_something_random

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
