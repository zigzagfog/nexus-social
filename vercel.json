{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/server.cjs": {
      "maxDuration": 30
    },
    "api/ping.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
